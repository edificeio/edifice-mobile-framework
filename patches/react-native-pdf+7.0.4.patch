+    // handleAlreadyClosed(), so AlreadyClosedBehavior.IGNORE is bypassed for that call.
+    // This handler silently drops the resulting IllegalStateException from the renderer thread.
+    private static volatile boolean pdfExceptionHandlerInstalled = false;
+
+    private static synchronized void installPdfRendererExceptionHandler() {
+        Thread.UncaughtExceptionHandler existing = Thread.getDefaultUncaughtExceptionHandler();
+        if (existing instanceof PdfRendererExceptionHandler) return;
+        Thread.setDefaultUncaughtExceptionHandler(new PdfRendererExceptionHandler(existing));
+        pdfExceptionHandlerInstalled = true;
+    }
+
+    private static final class PdfRendererExceptionHandler implements Thread.UncaughtExceptionHandler {
+        private final Thread.UncaughtExceptionHandler delegate;
+
+        PdfRendererExceptionHandler(Thread.UncaughtExceptionHandler delegate) {
+            this.delegate = delegate;
+        }
+
+        @Override
+        public void uncaughtException(Thread thread, Throwable throwable) {
+            if ("PDF renderer".equals(thread.getName())
+                    && throwable instanceof IllegalStateException
+                    && "Already closed".equals(throwable.getMessage())) {
+                return;
+            }
+            if (delegate != null) {
+                delegate.uncaughtException(thread, throwable);
+            }
+        }
     }
 
