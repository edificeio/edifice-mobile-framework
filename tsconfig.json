{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "alwaysStrict": true,
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "jsx": "react-native",
    "lib": ["esnext"],
    "module": "commonjs",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noErrorTruncation": true,
    "noImplicitAny": false,
    "paths": {
      "~/*": ["./src/*"],
      "ASSETS/*": ["./assets/*"]
    },
    "types": ["react-native", "node", "jest"],
    "resolveJsonModule": true,
    "rootDir": ".",
    "skipLibCheck": true,
    "strict": true ,
    "target": "esnext",
  },
  "exclude": ["__tests__/**/*-test.ts","__overrides__/**/*","__stashSpec__/**/*","scaffolder/**/*","**/node_modules","**/Pods"],
  "extends": ["@react-native/typescript-config"],
  "include": ["**/*.ts", "**/*.tsx"],
}
